# Site
NEXT_PUBLIC_SITE_URL=https://viviannedossantos.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# PayPal
# Vai a developer.paypal.com > Apps & Credentials
# Sandbox: usa as credenciais do tab Sandbox para testar
# Live: usa as credenciais do tab Live para receber dinheiro real
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Resend (email pos-compra)
# Vai a resend.com, cria conta, copia API Key
RESEND_API_KEY=

# Anthropic (gerador de prompts MJ no Estudio)
# console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# Replicate (geracao automatica de imagens no Estudio)
# replicate.com > Account > API Tokens
# Usado para gerar imagens dos slides via Flux 1.1 Pro
REPLICATE_API_TOKEN=

# Supabase bucket onde guardar as imagens geradas pelo Estudio
# Default: viviannepag-estudio (se nao definida)
# Estrutura interna: dia-N/slide-IDX-TIPO-TS.jpg
SUPABASE_BUCKET_ESTUDIO=viviannepag-estudio

# Google (opcional)
NEXT_PUBLIC_GA_ID=
GOOGLE_SITE_VERIFICATION=
