# Site
NEXT_PUBLIC_SITE_URL=https://viviannedossantos.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# PayPal
# Vai a developer.paypal.com > Apps & Credentials
# Sandbox: usa as credenciais do tab Sandbox para testar
# Live: usa as credenciais do tab Live para receber dinheiro real
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Resend (email pos-compra)
# Vai a resend.com, cria conta, copia API Key
RESEND_API_KEY=

# Anthropic (gerador de prompts MJ no Estudio)
# console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# Replicate (geracao automatica de imagens no Estudio)
# replicate.com > Account > API Tokens
# Usado para gerar imagens dos slides via Flux 1.1 Pro
REPLICATE_API_TOKEN=

# Google (opcional)
NEXT_PUBLIC_GA_ID=
GOOGLE_SITE_VERIFICATION=

# ElevenLabs (voz para reels sem filmagem)
# elevenlabs.io > Profile + API Key. Voice ID na pagina da voz clonada.
# Usado pelo GitHub Action de render-reels para gerar MP3 + timestamps de palavras.
ELEVENLABS_API_KEY=
ELEVEN_VOICE_ID=

# TikTok (Content Posting API) — publicacao da veu.a.veu no TikTok
# developers.tiktok.com > Manage apps > a tua app "veu.a.veu" > Client key/secret.
# A app tem de pedir os scopes: user.info.basic, video.upload, video.publish.
# Sem auditoria so publica em rascunho/privado; publico exige passar a auditoria.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# (opcional) fixa o redirect do OAuth; por defeito usa <origem>/api/admin/tiktok/callback
# Tem de bater certo com o "Redirect URI" registado no portal do TikTok.
TIKTOK_REDIRECT_URI=
